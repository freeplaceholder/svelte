{
  "name": "@freeplaceholder/svelte",
  "version": "0.1.0",
  "description": "Svelte components for FreePlaceholder.com placeholder images and avatars",
  "license": "MIT",
  "author": "Twenty Miles West",
  "homepage": "https://freeplaceholder.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeplaceholder/svelte.git"
  },
  "keywords": [
    "placeholder",
    "avatar",
    "image",
    "svelte",
    "freeplaceholder"
  ],
  "type": "module",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "svelte": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "svelte-package",
    "dev": "svelte-package --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@freeplaceholder/core": "git+https://github.com/freeplaceholder/core.git"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
